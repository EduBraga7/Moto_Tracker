# Copie este arquivo para .env e ajuste os valores

# Senha de acesso do app
APP_PASSWORD=admin

# Chave de sessão do Flask
FLASK_SECRET_KEY=troque-esta-chave-em-producao

# Ambiente local
FLASK_ENV=development
PORT=5000

# Firebase
# JSON completo em linha unica (ideal para Vercel)
# FIREBASE_KEY={"type":"service_account",...}
